    {
      "name": "02 - Users",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Ahmed Ali\",\n  \"phoneNumber\": \"+201000000000\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/users",
            "description": "Creates a user and stores returned userId in collection variable."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Response includes data.id', function () {",
                  "    pm.expect(json).to.have.property('data');",
                  "    pm.expect(json.data).to.have.property('id');",
                  "});",
                  "",
                  "if (json && json.data && json.data.id) {",
                  "    pm.collectionVariables.set('userId', String(json.data.id));",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Register Device Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"fake-device-token-{{$timestamp}}\",\n  \"platform\": \"{{platform}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/users/{{userId}}/device-tokens",
            "description": "Registers a device token for the selected user."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
